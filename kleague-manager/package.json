{
  "name": "kleague-manager",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @kleague-manager/engine build && pnpm --filter @kleague-manager/web build",
    "dev:web": "pnpm --filter @kleague-manager/engine build && pnpm --filter @kleague-manager/web dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
